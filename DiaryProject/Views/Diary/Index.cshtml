@model IEnumerable<DiaryProject.Models.DiaryEntry>

@{
    ViewData["Title"] = "Мій Щоденник";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h2 class="text-dark"><i class="bi bi-book"></i> Мої записи</h2>
       
        <a asp-action="Create" class="btn btn-dark shadow-sm">
            ➕ Додати запис
        </a>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                
                <div class="alert alert-secondary text-center shadow-sm bg-white border-0 text-muted">
                    Ваш щоденник поки що порожній. Додайте свій перший запис!
                </div>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-white">
                        <div class="card-body">
                            <h5 class="card-title text-dark fw-bold">@item.Title</h5>
                            <h6 class="card-subtitle mb-3 text-secondary" style="font-size: 0.85em;">
                                📅 @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                            </h6>
                            <p class="card-text text-muted">@item.Content</p>
                        </div>
                        <div class="card-footer bg-white border-top border-light text-end pb-3">
                         
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">✏️ Редагувати</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">🗑 Видалити</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>